# =============================================================================
# Kangur Backend (.env.example)
# Copy to .env.local (local) or set in Vercel Project → Settings → Environment
# Variables. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App / URLs
# -----------------------------------------------------------------------------
# Canonical public URL of this API (no trailing slash).
# Local:  http://localhost:3000
# Prod:   https://api.your-domain.com  (or your Vercel production URL)
APP_URL=

# Same value exposed to the Next.js client bundle when needed (webhooks UI, etc.)
NEXT_PUBLIC_APP_URL=

# Optional: explicit API base if it differs from APP_URL (usually leave empty)
# NEXT_PUBLIC_API_URL=

# Comma-separated. Required for Expo web / browser clients.
# Local default (when unset in development): http://localhost:8081,http://127.0.0.1:8081
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# -----------------------------------------------------------------------------
# Vercel (usually auto-injected — do not set manually in Vercel UI)
# Documented here so local tooling / scripts know they exist in deployed envs.
# https://vercel.com/docs/environment-variables/system-environment-variables
# -----------------------------------------------------------------------------
# VERCEL=1
# VERCEL_ENV=development|preview|production
# VERCEL_URL=                    # host without protocol, e.g. kangur-xxx.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL= # production hostname
# VERCEL_GIT_COMMIT_SHA=
# VERCEL_GIT_COMMIT_REF=

# Optional: protect cron / internal routes if you add Vercel Cron later
# CRON_SECRET=

# -----------------------------------------------------------------------------
# Neon (Postgres) + Prisma
# Prefer Neon → Vercel integration to sync DATABASE_URL per environment.
# Use pooled connection for the app; direct for Prisma migrate.
# Do NOT use Prisma Accelerate on MVP.
# -----------------------------------------------------------------------------
# Pooled (runtime / serverless), e.g. ...-pooler.region.aws.neon.tech
DATABASE_URL=

# Direct (migrations / prisma migrate deploy), e.g. ...region.aws.neon.tech
DIRECT_URL=

# -----------------------------------------------------------------------------
# Clerk (email/password + Google in M02; Apple deferred — prepare Dashboard later)
# https://dashboard.clerk.com
# Allow unverified email for MVP Android testing.
# -----------------------------------------------------------------------------
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Comma-separated emails auto-promoted to platformRole=ADMIN on upsert (one-way).
# Never auto-demotes. Empty = no bootstrap. Per-environment (local / Preview / Production).
# PLATFORM_ADMIN_EMAILS=chris@example.com,ops@kangur.app

# Emit metrics to console (backend). Default off — use InMemory + Noop only.
# METRICS_DEBUG=1

# Optional Clerk URLs if you customize paths
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------------------------
# OpenAI (AI SDK — vision + structured outputs)
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# Free plan monthly AI Credits per workspace (integer)
AI_FREE_MONTHLY_CREDITS=30

# Optional model overrides (defaults live in code)
# OPENAI_MODEL_TEXT=
# OPENAI_MODEL_VISION=

# -----------------------------------------------------------------------------
# Stripe (workspace Premium subscription)
# https://dashboard.stripe.com
# Local webhooks: stripe listen --forward-to localhost:3000/api/v1/billing/webhook
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Email invitations (Resend)
# When unset, invites still work — accept URL is logged + returned for copy in UI.
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# EMAIL_FROM=Kangur <onboarding@resend.dev>
# Deep-link / web base for invite accept links (no trailing slash)
INVITE_ACCEPT_URL_BASE=kangur://invite

# -----------------------------------------------------------------------------
# Observability / misc (optional for MVP)
# -----------------------------------------------------------------------------
# LOG_LEVEL=info
# NODE_ENV=development
