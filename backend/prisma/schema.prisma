// Kangur domain identity. Profile UI (name, avatar) stays in Clerk.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum ShoppingMode {
  shopping
  editing
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
}

enum ListStatus {
  active
  archived
}

enum ShoppingEventType {
  list_created
  item_created
  item_updated
  item_status_changed
  ai_applied
}

enum ItemStatus {
  pending
  bought
  unavailable
  removed
}

enum ShoppingCategory {
  produce
  fruit
  vegetables
  dairy
  meat
  fish
  bakery
  frozen
  drinks
  alcohol
  snacks
  household
  cleaning
  baby
  pets
  pharmacy
  cosmetics
  electronics
  office
  garden
  diy
  other
}

enum AiIngestSource {
  text
  screenshot
  clipboard
}

enum AiIngestStatus {
  proposed
  applied
  abandoned
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  locale    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        WorkspaceMember[]
  createdWorkspaces  Workspace[]       @relation("WorkspaceCreator")
  createdShoppingLists ShoppingList[]  @relation("ShoppingListCreator")
}

model Workspace {
  id              String   @id @default(cuid())
  name            String
  icon            String
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy    User               @relation("WorkspaceCreator", fields: [createdByUserId], references: [id])
  members      WorkspaceMember[]
  settings     WorkspaceSettings?
  subscription Subscription?
  lists        ShoppingList[]
  aiUsage      AIUsage[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceSettings {
  workspaceId          String       @id
  language             String
  notificationsEnabled Boolean      @default(true)
  realtimeSound        Boolean      @default(false)
  realtimeVibration    Boolean      @default(true)
  shoppingMode         ShoppingMode @default(editing)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(cuid())
  workspaceId          String             @unique
  status               SubscriptionStatus
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AIUsage {
  id            String   @id @default(cuid())
  workspaceId   String
  periodStart   DateTime
  aiCreditsUsed Int      @default(0)
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodStart])
}

model ShoppingList {
  id              String     @id @default(cuid())
  workspaceId     String
  name            String
  emoji           String
  status          ListStatus @default(active)
  createdByUserId String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User            @relation("ShoppingListCreator", fields: [createdByUserId], references: [id])
  events    ShoppingEvent[]
  items     ShoppingItem[]
  aiRuns    AiIngestRun[]

  @@index([workspaceId, status])
}

model ShoppingEvent {
  id          String            @id @default(cuid())
  listId      String
  actorUserId String
  type        ShoppingEventType
  payload     Json?
  createdAt   DateTime          @default(now())

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId, id])
}

model ShoppingItem {
  id              String           @id @default(cuid())
  clientId        String?          @unique
  listId          String
  name            String
  normalizedName  String?
  amount          String?
  note            String?
  category        ShoppingCategory
  status          ItemStatus       @default(pending)
  sortOrder       Int              @default(0)
  addedByUserId   String
  updatedByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId, status])
}

model AiIngestRun {
  id            String         @id @default(cuid())
  listId        String
  userId        String
  source        AiIngestSource
  status        AiIngestStatus
  model         String
  promptVersion String
  durationMs    Int?
  rawResponse   Json
  proposal      Json
  createdAt     DateTime       @default(now())
  appliedAt     DateTime?

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId, createdAt])
}
