{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "test:locales": "tsx scripts/check-locales.ts",
    "eval:ai": "tsx evals/runner/cli.ts",
    "eval:prune-reports": "tsx evals/runner/cli.ts --prune-only",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^9.0.0",
    "@clerk/backend": "^3.11.6",
    "@prisma/client": "^6.19.3",
    "next": "16.2.10",
    "openai": "^6.47.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "stripe": "^22.3.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.3",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
