{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sync-shared": "node scripts/sync-shared.js",
    "postinstall": "node scripts/sync-shared.js",
    "eas-build-pre-install": "node scripts/sync-shared.js",
    "start": "node scripts/sync-shared.js && expo start --dev-client",
    "start:go": "node scripts/sync-shared.js && expo start --go",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "eas:login": "eas login",
    "eas:build:android": "eas build --platform android --profile development"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.6",
    "expo-auth-session": "^57.0.3",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.5",
    "expo-crypto": "^57.0.1",
    "expo-dev-client": "~57.0.6",
    "expo-device": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image-picker": "~57.0.4",
    "expo-keep-awake": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "^57.0.1",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.6",
    "expo-secure-store": "^57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "i18next": "^26.3.6",
    "nativewind": "^4.2.6",
    "posthog-react-native": "^4.58.0",
    "@sentry/react-native": "~7.11.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.10",
    "react-native": "0.86.0",
    "react-native-css-interop": "^0.2.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.2",
    "eas-cli": "^21.0.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "^57.0.0",
    "typescript": "~6.0.3"
  }
}
