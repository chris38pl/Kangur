# =============================================================================
# Kangur Mobile - Expo (.env.example)
# Copy to .env (or .env.local per Expo docs). Use EXPO_PUBLIC_* for client-visible
# values only. Never put OpenAI, Stripe secrets, Clerk secret, or DATABASE_URL here.
# =============================================================================

# -----------------------------------------------------------------------------
# Platform API (Kangur backend on Vercel / local Next.js)
# No trailing slash.
# - Expo web / same PC: http://localhost:3000
# - Physical device: your machine LAN IP, e.g. http://192.168.1.24:3000
#   (phone must be on the same Wi‑Fi). NEVER use localhost on a physical device.
# - Android emulator: http://10.0.2.2:3000 often works; LAN IP is still fine.
# If you see Failed to fetch / timeouts: LAN IP often drifts (DHCP) - run
# `ipconfig` (Windows) and update this value, then restart Expo (env is not HMR'd).
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# Clerk (same publishable key as backend NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY)
# Enable email/password + Google in Clerk Dashboard for M02.
# Allow unverified emails for MVP Android testing.
# Native redirect scheme: kangur:// (see app.json "scheme")
# Add Google redirect URIs in Clerk (Expo / native callback).
# Apple Sign In is deferred - prepare Dashboard later (not implemented in M02).
# -----------------------------------------------------------------------------
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# App / environment hints (optional)
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_APP_ENV=development|preview|production

# AI proposal review UI. Default off (auto-apply after ingest).
# Set to "true" to require manual accept/reject of AI proposals.
EXPO_PUBLIC_AI_REVIEW_ENABLED=false

# History → AI list suggestions FAB option. Default on when unset.
# EXPO_PUBLIC_HISTORY_SUGGESTIONS_ENABLED=true|false

# EAS / native builds: set the same EXPO_PUBLIC_* in eas.json env or EAS Secrets.
# https://docs.expo.dev/eas/environment-variables/

# Optional: Discord invite for Help & support → Community row
# EXPO_PUBLIC_DISCORD_URL=https://discord.gg/your-invite

# Public Kangur inboxes (defaults in app: contact@ / support@ getkangur.com)
# EXPO_PUBLIC_CONTACT_EMAIL=contact@getkangur.com
# EXPO_PUBLIC_SUPPORT_EMAIL=support@getkangur.com
